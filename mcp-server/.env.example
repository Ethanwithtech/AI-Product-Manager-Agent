# PM Team Hub — 环境变量配置
# 复制此文件为 .env 并根据实际环境修改

# ─── 服务器配置 ───
# 本地开发用 127.0.0.1，团队共享用 0.0.0.0
HOST=0.0.0.0
PORT=8000

# ─── 数据库 ───
DATABASE_URL=sqlite:///./data/pm_team_hub.db

# ─── ChromaDB 向量数据库 ───
CHROMA_PERSIST_DIR=./data/chroma

# ─── CORS 跨域 ───
# 多个域名用逗号分隔，团队部署时改为具体前端地址
# 例如: http://10.0.1.100:5173,http://10.0.1.100:3000
CORS_ORIGINS=*

# ─── JWT 认证 ───
# 生产环境务必修改此密钥！
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Skills 和 Agents 目录 ───
# 默认自动检测项目目录，部署到服务器时需要指定绝对路径
# SKILLS_DIR=/opt/pm-hub/skills
# AGENTS_DIR=/opt/pm-hub/agents
