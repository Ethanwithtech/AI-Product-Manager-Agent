# PM Team Hub — Environment Configuration
# Copy this file to .env and customize values

# ──── Ports ────
MCP_PORT=8000
WEB_PORT=3000

# ──── Security ────
# JWT secret for web admin authentication (MUST change in production)
JWT_SECRET=change-me-in-production

# Optional: access token for MCP endpoint protection
# If set, CodeBuddy clients must include this token in MCP config
ACCESS_TOKEN=

# ──── Database ────
# SQLite database path (relative to mcp-server working directory)
DATABASE_URL=sqlite:///data/pm_team_hub.db

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data

# ──── CORS ────
# Comma-separated list of allowed origins (* for development)
CORS_ORIGINS=*

# ──── MCP Server ────
HOST=0.0.0.0
PORT=8000

# Skills directory path (for reading local skill definitions)
SKILLS_DIR=../skills
